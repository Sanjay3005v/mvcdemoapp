    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model IEnumerable<mvcdemoapp.Models.Customer>
@{
    ViewData["Title"] = "Customer Details";
}

<h2 class="mb-4">@ViewData["Title"]</h2>
<a asp-action="Create"> Add Customer</a>
<table>
    <thead>
        <tr>
            <th scope="col">First Name</th>
            <th scope="col">Last Name</th>
            <th scope="col">Email</th>
            <th scope="col">PhoneNumber</th>
            <th scope="col">Created_At</th>
            <th scope="col">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td>@customer.FirstName</td>
                <td>@customer.LastName</td>
                <td>@customer.Email</td>
                <td>@customer.PhoneNumber</td>
                <td>@customer.CreatedAt</td>
                <td>
                    <a asp-action="Details" asp-route-id="@customer.CustomerId" ">View Details</a>
                    <a asp-action="Edit" asp-route-id="@customer.CustomerId" ">Edit Detail</a>
                    <a asp-action="Delete" asp-route-id="@customer.CustomerId" ">Delete</a>
                </tr>
            }
        </tbody>
    </table>
