@model mvcdemoapp.Models.Product;
@{
    ViewData["Title"] = "Delete Product";
}

<h2>Delete Product</h2>

<h4 class="text-danger">Are you sure you want to delete this product</h4>
<hr />

<div class="mb-3">
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.ProductName</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.ProductDescription</dd>

        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.ProductCategory</dd>

        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">@Model.ProductPrice</dd>

        <dt class="col-sm-2">Available</dt>
        <dd class="col-sm-10">@(Model.IsAvailable ? "Yes" : "No")</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ProductId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index">Back to Catalog</a>
</form>
