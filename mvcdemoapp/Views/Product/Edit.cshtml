@{
}
@model Product

<h2>Edit Product</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ProductId" />

    <div>
        <label>Name</label>
        <input asp-for="ProductName" />
    </div>

    <div>
        <label>Description</label>
        <input asp-for="ProductDescription" />
    </div>

    <div>
        <label>Category</label>
        <input asp-for="ProductCategory" />
    </div>

    <div>
        <label>Price</label>
        <input asp-for="ProductPrice" type="number" />
    </div>

    <div>
        <label>Available</label>
        <input asp-for="IsAvailable" type="checkbox" />
    </div>

    <button type="submit">Update</button>
    <a asp-action="Index">Back to Catalog</a>
</form>
